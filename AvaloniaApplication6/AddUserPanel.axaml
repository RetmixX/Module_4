<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="AvaloniaApplication6.AddUserPanel"
        Title="Добавление пользователя">
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
       <Label HorizontalAlignment="Center" VerticalAlignment="Center">Добавление пользователя</Label>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" >
            <Label>Логин: </Label>
            <TextBox Width="300" x:Name="Login"></TextBox>
        </StackPanel>
        <StackPanel >
            <Label>Пароль: </Label>
            <TextBox Width="300" x:Name="Password"></TextBox>
        </StackPanel>
        <StackPanel >
            <Label>Роль: </Label>
            <TextBox Width="300" x:Name="Role"></TextBox>
        </StackPanel>
        <Button Margin="0, 10, 0, 0" Click="AddNewUser">Добавить</Button>
        <Label Margin="0, 10, 0, 0" x:Name="ErrorMsg" Foreground="Red"></Label>
    </StackPanel>
</Window>
